# Environment variables for Helpdesk RPA Automation

# Enable debug logging (optional)
DEBUG=false

# GitLab Configuration
GITLAB_BASE_URL=http://your-gitlab-host
GITLAB_TOKEN=your-gitlab-token

# Helpdesk portal URL.
# Use the new ticket page URL. The app derives list/process URLs from this value.
HELPDESK_URL=https://your-helpdesk-host/helpdesk/it/new_helpdesk

# Client-visible helpdesk URL for the login link shown in the UI.
NEXT_PUBLIC_HELPDESK_URL=https://your-helpdesk-host/helpdesk/it/new_helpdesk

# Playwright browser path (optional, will use bundled/default browser if empty)
PLAYWRIGHT_BROWSER_PATH=

# AI Configuration (for GitLab commit message transformation)
OPENAI_BASE_URL=https://your-openai-compatible-host/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o
