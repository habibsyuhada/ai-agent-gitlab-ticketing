# Environment variables for Helpdesk RPA Automation

# Enable debug logging (optional)
# DEBUG=true

# Playwright browser path (optional, will use system default if not specified)
# PLAYWRIGHT_BROWSER_PATH=

# Target helpdesk URL (optional, defaults to https://iss.smoebatam.com/helpdesk/it/new_helpdesk)
# HELPDESK_URL=https://iss.smoebatam.com/helpdesk/it/new_helpdesk
